---
import PopupShell from "./PopupShell.astro";

const {
  id,
  label = "証明",
} = Astro.props;

type MdxModule = {
  default: any;
  frontmatter?: {
    title?: string;
  };
};

const modules = import.meta.glob<MdxModule>(
  "../../content/proofs/**/*.mdx",
  { eager: true }
);

const path = `../../content/proofs/${id}.mdx`;
const entry = modules[path];

if (!entry) {
  throw new Error(`Proof popup not found: ${id}`);
}

const Content = entry.default;
const title = entry.frontmatter?.title ?? id;
---

<PopupShell label={label} title={title} kind="proof">
  <Content />
</PopupShell>